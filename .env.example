# Metro Intelligence Platform — environment template
# Copy to .env and fill with local values. NEVER commit .env.
# Every value below is a placeholder — no real credentials.

# --- Application ---
APP_ENV=development                # development | staging | production
APP_SECRET_KEY=changeme-generate-a-random-64-char-string
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL 16) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=metro_intelligence
POSTGRES_USER=metro_app
POSTGRES_PASSWORD=changeme-local-only

# --- Auth ---
JWT_SECRET=changeme-generate-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Object storage (MinIO, on-premise) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_RAW_FILES=raw-measurement-files
MINIO_USE_TLS=false               # true in any non-local environment

# --- Seed data (demo) ---
SEED_DEMO_USER_PASSWORD=changeme-local-only   # intended password for the demo RBAC users (seed/generators/users.py); hashing happens in F4.2

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Observability (optional in demo) ---
LOG_LEVEL=INFO
ENABLE_METRICS=true
