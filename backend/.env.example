# ###########################################################################
# Metro Intelligence Platform — Required & optional environment variables
# ###########################################################################
# Copy this file to .env for local development. In production / Docker Compose
# every variable below is supplied by the deployment infrastructure (Docker
# Compose / Kubernetes secrets / HashiCorp Vault) — .env is never read there.
# ###########################################################################

# ---------- General ----------
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=DEBUG

# ---------- PostgreSQL ----------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=metro_dev_pw
POSTGRES_DB=metro_dev

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------- MinIO / object storage ----------
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=metro_minio_dev
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET_RAW_FILES=metro-raw-files
MINIO_USE_SSL=false

# ---------- JWT (F4.2 / MI-22) ----------
JWT_SECRET=change-me-in-production-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
